// ---------------------------------------------------------------------------
// Tab: SWOT Upload
// ---------------------------------------------------------------------------

interface SWOTRow extends PreviewRowBase {
  fiplCode: string;
  strengths: string[];
  weaknesses: string[];
  opportunities: string[];
  threats: string[];
  traits: string[];
  problems: string[];
  feedbacks: string[];
  cesScore: number;
}

const SWOT_HEADERS = [
  "FIPL Code",
  "Strengths",
  "Weaknesses",
  "Opportunities",
  "Threats",
  "Traits",
  "Problems",
  "Feedbacks",
];

function splitSemi(val: unknown): string[] {
  return str(val)
    .split(";")
    .map((s) => s.trim())
    .filter(Boolean);
}

function parseSWOTRows(
  rawRows: Record<string, unknown>[],
  employeeSet: Set<string>,
): SWOTRow[] {
  return rawRows
    .filter((r) => SWOT_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const fiplCode = str(r["FIPL Code"]);

      if (!fiplCode) errors.push("FIPL Code is required");
      else if (!employeeSet.has(fiplCode.toUpperCase()))
        errors.push("Invalid FIPL Code");

      return {
        fiplCode,
        strengths: splitSemi(r.Strengths),
        weaknesses: splitSemi(r.Weaknesses),
        opportunities: splitSemi(r.Opportunities),
        threats: splitSemi(r.Threats),
        traits: splitSemi(r.Traits),
        problems: splitSemi(r.Problems),
        feedbacks: splitSemi(r.Feedbacks),
        cesScore: 0,
        errors,
      };
    });
}

function SWOTUploadTab() {
  const { actor, isFetching } = useActor();
  const queryClient = useQueryClient();
  const [parsedRows, setParsedRows] = useState<SWOTRow[] | null>(null);
  const [parseError, setParseError] = useState<string | null>(null);
  const [fileName, setFileName] = useState<string | null>(null);

  const { data: employees = [] } = useQuery({
    queryKey: ["employees"],
    queryFn: async () => (actor ? actor.getAllEmployees() : []),
    enabled: !!actor && !isFetching,
  });
  const employeeSet = new Set(
    employees.map((e) => e.fiplCode.trim().toUpperCase()),
  );

  const mutation = useMutation({
    mutationFn: async (records: SWOT[]) => {
      if (!actor) throw new Error("Not connected");
      return actor.batchSWOTUpload(records);
    },
    onSuccess: (result) => {
      toast.success(
        `${Number(result.successCount)} rows uploaded, ${Number(result.failCount)} failed`,
      );
      queryClient.invalidateQueries({ queryKey: ["swot"] });
      setParsedRows(null);
      setFileName(null);
    },
    onError: (err) => toast.error(`Upload failed: ${String(err)}`),
  });

  const handleFileSelect = async (file: File) => {
    setParseError(null);
    setParsedRows(null);
    setFileName(file.name);
    try {
      const rawRows = await parseWorkbook(file);
      if (rawRows.length === 0) {
        setParseError("File is empty.");
        return;
      }
      const missing = SWOT_HEADERS.filter((h) => !(h in rawRows[0]));
      if (missing.length > 0) {
        setParseError(`Missing columns: ${missing.join(", ")}`);
        return;
      }
      setParsedRows(parseSWOTRows(rawRows, employeeSet));
    } catch (e) {
      setParseError(`Failed to parse: ${String(e)}`);
    }
  };

  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];

  const handleConfirm = () => {
    const records: SWOT[] = validRows.map((r) => ({
      fiplCode: r.fiplCode,
