        "FIPL001",
        "Team player;Leadership",
        "Needs improvement;Time management",
        "Upselling;Cross-sell",
        "Competition;Market shift",
        "Analytical;Detail-oriented",
        "Delayed follow-up",
        "satisfaction|high|Customer happy;service|medium|Response slow",
      ]}
      parsedRows={parsedRows}
      parseError={parseError}
      fileName={fileName}
      isPending={mutation.isPending}
      onFileSelect={handleFileSelect}
      onClear={() => {
        setParsedRows(null);
        setFileName(null);
        setParseError(null);
      }}
      onConfirm={handleConfirm}
      tableHeaders={[
        "FIPL Code",
        "Strengths",
        "Weaknesses",
        "Opportunities",
        "Threats",
        "Traits",
        "Problems",
        "Feedbacks",
      ]}
      renderRow={(row) => (
        <>
          <TableCell className="font-mono text-xs">
            {row.fiplCode || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.strengths.join("; ") || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.weaknesses.join("; ") || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.opportunities.join("; ") || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.threats.join("; ") || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.traits.join("; ") || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.problems.join("; ") || "2014"}
          </TableCell>
          <TableCell className="text-xs">
            {row.feedbacks.join("; ") || "2014"}
          </TableCell>
        </>
      )}
    />
  );
}

// ---------------------------------------------------------------------------
// Tab: Sales Upload
// ---------------------------------------------------------------------------

const SALES_BRANDS = ["Ecovacs", "Kuvings", "Coway", "Tineco", "Instant"];
const SALES_TYPES = ["Accessories", "Extended Warranty"];

interface SalesRow extends PreviewRowBase {
  fiplCode: string;
  name: string;
  brand: string;
  product: string;
  saleType: string;
  date: string;
  quantity: number;
  amount: number;
}

const SALES_HEADERS = [
  "FIPL Code",
  "Name",
  "Brand",
  "Product",
  "Type",
  "Date (DD-MM-YYYY)",
  "Quantity",
  "Amount (₹)",
];

function parseSalesRows(
  rawRows: Record<string, unknown>[],
  employeeSet: Set<string>,
): SalesRow[] {
  return rawRows
    .filter((r) => SALES_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const fiplCode = str(r["FIPL Code"]);
      const brand = str(r.Brand);
      const saleType = str(r.Type);
      const qtyRaw = cleanNumeric(r.Quantity);
      const amtRaw = cleanNumeric(r["Amount (₹)"]);
      const qty = Number(qtyRaw);
      const amt = Number(amtRaw);

      if (!fiplCode) errors.push("FIPL Code is required");
      else if (!employeeSet.has(fiplCode.toUpperCase()))
        errors.push("Invalid FIPL Code");

      if (
        !SALES_BRANDS.map((b) => b.toLowerCase()).includes(brand.toLowerCase())
      ) {
        errors.push(`Brand must be one of: ${SALES_BRANDS.join(", ")}`);
      }
      if (
        !SALES_TYPES.map((t) => t.toLowerCase()).includes(
          saleType.toLowerCase(),
        )
      ) {
        errors.push(`Type must be: ${SALES_TYPES.join(" or ")}`);
      }
      if (qtyRaw === "" || Number.isNaN(qty) || qty < 0)
        errors.push("Quantity must be >= 0");
      if (amtRaw === "" || Number.isNaN(amt) || amt < 0)
        errors.push("Amount must be >= 0");

      return {
        fiplCode,
        name: str(r.Name),
        brand,
        product: str(r.Product),
        saleType,
        date: str(r["Date (DD-MM-YYYY)"]),
        quantity: Number.isNaN(qty) ? 0 : qty,
        amount: Number.isNaN(amt) ? 0 : amt,
        errors,
      };
    });
}

function SalesUploadTab() {
  const { actor, isFetching } = useActor();
  const queryClient = useQueryClient();
  const [parsedRows, setParsedRows] = useState<SalesRow[] | null>(null);
  const [parseError, setParseError] = useState<string | null>(null);
  const [fileName, setFileName] = useState<string | null>(null);

  const { data: employees = [] } = useQuery({
    queryKey: ["employees"],
    queryFn: async () => (actor ? actor.getAllEmployees() : []),
    enabled: !!actor && !isFetching,
  });
  const employeeSet = new Set(
    employees.map((e) => e.fiplCode.trim().toUpperCase()),
  );

  const mutation = useMutation({
    mutationFn: async (records: SalesRecord[]) => {
      if (!actor) throw new Error("Not connected");
      return actor.batchSalesUpload(records);
    },
    onSuccess: (result) => {
      toast.success(
        `${Number(result.successCount)} rows uploaded, ${Number(result.failCount)} failed`,
      );
      queryClient.invalidateQueries({ queryKey: ["sales"] });
      setParsedRows(null);
      setFileName(null);
    },
    onError: (err) => toast.error(`Upload failed: ${String(err)}`),
  });

  const handleFileSelect = async (file: File) => {
    setParseError(null);
    setParsedRows(null);
    setFileName(file.name);
    try {
      const rawRows = await parseWorkbook(file);
      if (rawRows.length === 0) {
        setParseError("File is empty.");
        return;
      }
      const missing = SALES_HEADERS.filter((h) => !(h in rawRows[0]));
      if (missing.length > 0) {
        setParseError(`Missing columns: ${missing.join(", ")}`);
        return;
      }
      setParsedRows(parseSalesRows(rawRows, employeeSet));
    } catch (e) {
      setParseError(`Failed to parse: ${String(e)}`);
    }
  };

  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];

  const brandMap: Record<string, Variant_tineco_ecovacs_coway_kuvings_instant> =
    {
      ecovacs: Variant_tineco_ecovacs_coway_kuvings_instant.ecovacs,
      kuvings: Variant_tineco_ecovacs_coway_kuvings_instant.kuvings,
      coway: Variant_tineco_ecovacs_coway_kuvings_instant.coway,
      tineco: Variant_tineco_ecovacs_coway_kuvings_instant.tineco,
      instant: Variant_tineco_ecovacs_coway_kuvings_instant.instant,
    };

  const typeMap: Record<string, Variant_accessories_extendedWarranty> = {
    accessories: Variant_accessories_extendedWarranty.accessories,
    "extended warranty": Variant_accessories_extendedWarranty.extendedWarranty,
  };

  const handleConfirm = () => {
    const records: SalesRecord[] = validRows.map((r) => ({
      recordId: 0n,
      fiplCode: r.fiplCode,
      brand: brandMap[r.brand.toLowerCase()],
      product: r.product,
      saleType: typeMap[r.saleType.toLowerCase()],
      quantity: BigInt(Math.round(r.quantity)),
      amount: r.amount,
      saleDate: r.date,
    }));
    mutation.mutate(records);
  };

  return (
    <UploadSection<SalesRow>
      tabId="sales_upload"
      title="Sales Upload"
      description="Upload sales records. Brands: Ecovacs, Kuvings, Coway, Tineco, Instant. Types: Accessories, Extended Warranty."
      icon={<TrendingUp size={17} className="text-primary" />}
      templateFilename="sales_template.xlsx"
      templateHeaders={SALES_HEADERS}
      templateExample={[
        "FIPL001",
        "Rahul Sharma",
        "Ecovacs",
        "T10 Pro",
        "Accessories",
        "15-03-2024",
        5,
        25000,
      ]}
      parsedRows={parsedRows}
      parseError={parseError}
      fileName={fileName}
      isPending={mutation.isPending}
      onFileSelect={handleFileSelect}
      onClear={() => {
        setParsedRows(null);
        setFileName(null);
        setParseError(null);
      }}
      onConfirm={handleConfirm}
      tableHeaders={[
        "FIPL Code",
        "Name",
        "Brand",
        "Product",
        "Type",
        "Date",
        "Qty",
        "Amount (₹)",
      ]}
      renderRow={(row) => (
        <>
          <TableCell className="font-mono text-xs">
            {row.fiplCode || "—"}
          </TableCell>
          <TableCell className="text-sm">{row.name || "—"}</TableCell>
          <TableCell className="text-xs">{row.brand || "—"}</TableCell>
          <TableCell className="text-xs">{row.product || "—"}</TableCell>
          <TableCell className="text-xs">{row.saleType || "—"}</TableCell>
          <TableCell className="text-xs">{row.date || "—"}</TableCell>
          <TableCell className="text-xs text-right">{row.quantity}</TableCell>
          <TableCell className="text-xs text-right">
            ₹{row.amount.toLocaleString("en-IN")}
          </TableCell>
        </>
      )}
    />
  );
}

// ---------------------------------------------------------------------------
// Tab: Calling Records Upload
// ---------------------------------------------------------------------------

interface CallingRow extends PreviewRowBase {
  fiplCode: string;
  fseName: string;
  customerName: string;
  contact: string;
  brand: string;
  product: string;
  cesScore: number;
  remark: string;
  callDate: string;
  agent: string;
}

const CALLING_HEADERS = [
  "FIPL Code",
  "FSE Name",
  "Customer Name",
  "Customer Contact",
  "Brand",
  "Product",
  "CES Score",
  "Remark",
  "Date of Call (DD-MM-YYYY)",
  "Agent",
];

function parseCallingRows(
  rawRows: Record<string, unknown>[],
  employeeSet: Set<string>,
): CallingRow[] {
  return rawRows
    .filter((r) => CALLING_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const fiplCode = str(r["FIPL Code"]);
      const brand = str(r.Brand);
      const cesRaw = cleanNumeric(r["CES Score"]);
      const ces = Number(cesRaw);

      if (!fiplCode) errors.push("FIPL Code is required");
      else if (!employeeSet.has(fiplCode.toUpperCase()))
        errors.push("Invalid FIPL Code");

      if (
        brand &&
        !SALES_BRANDS.map((b) => b.toLowerCase()).includes(brand.toLowerCase())
      ) {
        errors.push(`Brand must be one of: ${SALES_BRANDS.join(", ")}`);
      }
      if (cesRaw !== "" && (Number.isNaN(ces) || ces < 0)) {
        errors.push("CES Score must be >= 0");
      }

      return {
        fiplCode,
        fseName: str(r["FSE Name"]),
        customerName: str(r["Customer Name"]),
        contact: str(r["Customer Contact"]),
        brand,
        product: str(r.Product),
        cesScore: Number.isNaN(ces) ? 0 : ces,
        remark: str(r.Remark),
        callDate: str(r["Date of Call (DD-MM-YYYY)"]),
        agent: str(r.Agent),
        errors,
      };
    });
}

