        Variant_tineco_ecovacs_coway_kuvings_instant.ecovacs,
      product: r.product,
      cesScore: r.cesScore,
      remark: r.remark,
      callDate: r.callDate,
      agent: r.agent,
    }));
    mutation.mutate(records);
  };

  return (
    <UploadSection<CallingRow>
      tabId="calling_upload"
      title="Calling Records Upload"
      description="Upload customer calling records and feedback. CES Score = customer satisfaction rating."
      icon={<Phone size={17} className="text-primary" />}
      templateFilename="calling_records_template.xlsx"
      templateHeaders={CALLING_HEADERS}
      templateExample={[
        "FIPL001",
        "Rahul Sharma",
        "Amit Kumar",
        "9876543210",
        "Ecovacs",
        "T10 Pro",
        90,
        "Customer satisfied",
        "15-03-2024",
        "Rahul Sharma",
      ]}
      parsedRows={parsedRows}
      parseError={parseError}
      fileName={fileName}
      isPending={mutation.isPending}
      onFileSelect={handleFileSelect}
      onClear={() => {
        setParsedRows(null);
        setFileName(null);
        setParseError(null);
      }}
      onConfirm={handleConfirm}
      tableHeaders={[
        "FIPL Code",
        "FSE Name",
        "Customer",
        "Contact",
        "Brand",
        "Product",
        "CES",
        "Remark",
        "Call Date",
        "Agent",
      ]}
      renderRow={(row) => (
        <>
          <TableCell className="font-mono text-xs">
            {row.fiplCode || "—"}
          </TableCell>
          <TableCell className="text-xs">{row.fseName || "—"}</TableCell>
          <TableCell className="text-xs">{row.customerName || "—"}</TableCell>
          <TableCell className="text-xs">{row.contact || "—"}</TableCell>
          <TableCell className="text-xs">{row.brand || "—"}</TableCell>
          <TableCell className="text-xs">{row.product || "—"}</TableCell>
          <TableCell className="text-xs text-right">{row.cesScore}</TableCell>
          <TableCell className="text-xs max-w-[120px] truncate">
            {row.remark || "—"}
          </TableCell>
          <TableCell className="text-xs">{row.callDate || "—"}</TableCell>
          <TableCell className="text-xs">{row.agent || "—"}</TableCell>
        </>
      )}
    />
  );
}

// ---------------------------------------------------------------------------
// Tab: Top Performers (preserved)
// ---------------------------------------------------------------------------

const TOP_PERFORMERS_HEADERS = [
  "Rank",
  "Name",
  "FIPL Code",
  "Accessories Units",
  "Extended Warranty Units",
  "Total Sales Amount",
];

interface TopPerformerRow extends PreviewRowBase {
  rank: number;
  name: string;
  fiplCode: string;
  accessories: number;
  extendedWarranty: number;
  totalSales: number;
}

function getRankBadge(rank: number) {
  if (rank === 1)
    return (
      <span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-700 border border-amber-300">
        🥇 1
      </span>
    );
  if (rank === 2)
    return (
      <span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-600 border border-slate-300">
        🥈 2
      </span>
    );
  if (rank === 3)
    return (
      <span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-orange-100 text-orange-700 border border-orange-300">
        🥉 3
      </span>
    );
  return (
    <span className="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-muted text-muted-foreground">
      {rank}
    </span>
  );
}

function parseTopPerformerRows(
  rawRows: Record<string, unknown>[],
  employeeSet: Set<string>,
): TopPerformerRow[] {
  const seenRanks = new Map<number, number>();
  const parsed: TopPerformerRow[] = rawRows
    .filter((r) => TOP_PERFORMERS_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const rankRaw = str(r.Rank);
      const fiplCode = str(r["FIPL Code"]);
      const rank = Number(rankRaw);

      if (!rankRaw || !Number.isInteger(rank) || rank < 1 || rank > 10)
        errors.push("Rank must be 1–10");
      if (!str(r.Name)) errors.push("Name is required");
      if (!fiplCode) errors.push("FIPL Code is required");
      else if (!employeeSet.has(fiplCode.toUpperCase()))
        errors.push("Invalid FIPL Code");

      const parseN = (key: string, label: string) => {
        const raw = cleanNumeric(r[key]);
        const n = Number(raw);
        if (raw === "" || Number.isNaN(n) || n < 0) {
          errors.push(`Invalid number (${label})`);
          return 0;
        }
        return n;
      };

      return {
        rank: Number.isInteger(rank) ? rank : 0,
        name: str(r.Name),
        fiplCode,
        accessories: parseN("Accessories Units", "Accessories Units"),
        extendedWarranty: parseN(
          "Extended Warranty Units",
          "Extended Warranty Units",
        ),
        totalSales: parseN("Total Sales Amount", "Total Sales Amount"),
        errors,
      };
    });

  parsed.forEach((row, idx) => {
    if (row.rank >= 1 && row.rank <= 10) {
      if (seenRanks.has(row.rank)) {
        row.errors.push("Duplicate rank");
        const firstIdx = seenRanks.get(row.rank)!;
        if (!parsed[firstIdx].errors.includes("Duplicate rank")) {
          parsed[firstIdx].errors.push("Duplicate rank");
        }
      } else {
        seenRanks.set(row.rank, idx);
      }
    }
  });
  return parsed;
}

function TopPerformersTab() {
  const { actor, isFetching } = useActor();
  const queryClient = useQueryClient();
  const [parsedRows, setParsedRows] = useState<TopPerformerRow[] | null>(null);
  const [parseError, setParseError] = useState<string | null>(null);
  const [fileName, setFileName] = useState<string | null>(null);

  const { data: topPerformers = [], isLoading } = useQuery<TopPerformer[]>({
    queryKey: ["topPerformers"],
    queryFn: async () => (actor ? actor.getTopPerformers() : []),
    enabled: !!actor && !isFetching,
  });

  const { data: employees = [] } = useQuery({
    queryKey: ["employees"],
    queryFn: async () => (actor ? actor.getAllEmployees() : []),
    enabled: !!actor && !isFetching,
  });
  const employeeSet = new Set(
    employees.map((e) => e.fiplCode.trim().toUpperCase()),
  );
  const employeeMap = new Map(
    employees.map((e) => [e.fiplCode.trim().toUpperCase(), e]),
  );

  const mutation = useMutation({
    mutationFn: async (records: TopPerformer[]) => {
      if (!actor) throw new Error("Not connected");
      return actor.batchTopPerformersUpload(records);
    },
    onSuccess: (result) => {
      toast.success(
        `${Number(result.successCount)} rows uploaded, ${Number(result.failCount)} failed`,
      );
      queryClient.invalidateQueries({ queryKey: ["topPerformers"] });
      setParsedRows(null);
      setFileName(null);
    },
    onError: (err) => toast.error(`Upload failed: ${String(err)}`),
  });

  const handleFileSelect = async (file: File) => {
    setParseError(null);
    setParsedRows(null);
    setFileName(file.name);
    try {
      const rawRows = await parseWorkbook(file);
      if (rawRows.length === 0) {
        setParseError("File is empty.");
        return;
      }
      const missing = TOP_PERFORMERS_HEADERS.filter((h) => !(h in rawRows[0]));
      if (missing.length > 0) {
        setParseError(`Missing columns: ${missing.join(", ")}`);
        return;
      }
      setParsedRows(parseTopPerformerRows(rawRows, employeeSet));
    } catch (e) {
      setParseError(`Failed to parse: ${String(e)}`);
    }
  };

  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];

  const handleConfirm = () => {
    const records: TopPerformer[] = validRows.map((r) => ({
      rank: BigInt(r.rank),
      name: r.name,
      fiplCode: r.fiplCode,
      accessories: BigInt(r.accessories),
      extendedWarranty: BigInt(r.extendedWarranty),
      totalSales: r.totalSales,
    }));
    mutation.mutate(records);
  };

  const sortedPerformers = [...topPerformers]
    .sort((a, b) => b.totalSales - a.totalSales)
    .slice(0, 10);

  return (
    <div className="space-y-4">
      <UploadSection<TopPerformerRow>
        tabId="top_performers"
        title="Top Performers Upload"
        description="Upload top 10 performer rankings. Ranks must be 1–10 with no duplicates."
        icon={<Trophy size={17} className="text-amber-500" />}
        templateFilename="top_performers_template.xlsx"
        templateHeaders={TOP_PERFORMERS_HEADERS}
        templateExample={[1, "Rahul Sharma", "FIPL001", 25, 10, 250000]}
        parsedRows={parsedRows}
        parseError={parseError}
        fileName={fileName}
        isPending={mutation.isPending}
        onFileSelect={handleFileSelect}
        onClear={() => {
          setParsedRows(null);
          setFileName(null);
          setParseError(null);
        }}
        onConfirm={handleConfirm}
        tableHeaders={[
          "Rank",
          "Name",
          "FIPL Code",
          "Accessories",
          "Ext. Warranty",
          "Total Sales (₹)",
        ]}
        renderRow={(row) => (
          <>
            <TableCell>{getRankBadge(row.rank)}</TableCell>
            <TableCell className="text-sm">{row.name || "—"}</TableCell>
            <TableCell className="font-mono text-xs">
              {row.fiplCode || "—"}
            </TableCell>
            <TableCell className="text-xs text-right">
              {row.accessories}
            </TableCell>
            <TableCell className="text-xs text-right">
              {row.extendedWarranty}
            </TableCell>
            <TableCell className="text-xs text-right">
              ₹{row.totalSales.toLocaleString("en-IN")}
            </TableCell>
          </>
        )}
      />

      {/* Current Top Performers Table */}
      <Card>
        <CardHeader className="pb-3">
          <CardTitle className="text-base font-semibold flex items-center gap-2">
            <Trophy size={16} className="text-amber-500" />
            Current Top 10 Performers
          </CardTitle>
        </CardHeader>
        <CardContent>
          {isLoading ? (
            <div
              className="flex items-center justify-center py-12 gap-2 text-muted-foreground"
              data-ocid="top_performers.loading_state"
            >
              <Loader2 size={16} className="animate-spin" />
              <span className="text-sm">Loading...</span>
            </div>
          ) : sortedPerformers.length === 0 ? (
            <div
              className="flex flex-col items-center justify-center py-12 text-center text-muted-foreground gap-3"
              data-ocid="top_performers.empty_state"
            >
              <FileSpreadsheet size={36} className="opacity-30" />
              <p className="text-sm font-medium">No data available</p>
              <p className="text-xs">Upload a file to populate this table.</p>
            </div>
          ) : (
            <div className="rounded-lg border border-border overflow-hidden">
              <Table>
                <TableHeader>
                  <TableRow className="bg-muted/50">
                    <TableHead className="w-16 text-xs">Rank</TableHead>
                    <TableHead className="text-xs">Name</TableHead>
                    <TableHead className="text-xs">FIPL Code</TableHead>
                    <TableHead className="text-xs text-right">
                      Accessories
                    </TableHead>
                    <TableHead className="text-xs text-right">
                      Ext. Warranty
                    </TableHead>
                    <TableHead className="text-xs text-right">
                      Total Sales (₹)
                    </TableHead>
                    <TableHead className="text-xs">Region</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {sortedPerformers.map((p, idx) => {
                    const rank = Number(p.rank);
                    const emp = employeeMap.get(
                      p.fiplCode.trim().toUpperCase(),
                    );
                    const rowClass =
                      rank === 1
                        ? "bg-amber-50 border-l-4 border-l-amber-400"
                        : rank === 2
                          ? "bg-slate-50 border-l-4 border-l-slate-400"
                          : rank === 3
                            ? "bg-orange-50 border-l-4 border-l-orange-400"
                            : "";
                    return (
                      <TableRow
                        key={p.fiplCode}
                        data-ocid={`top_performers.item.${idx + 1}`}
                        className={rowClass}
                      >
                        <TableCell>{getRankBadge(rank)}</TableCell>
                        <TableCell className="font-medium text-sm">
                          {p.name}
                        </TableCell>
                        <TableCell className="font-mono text-xs text-muted-foreground">
                          {p.fiplCode}
                        </TableCell>
                        <TableCell className="text-sm text-right">
                          {Number(p.accessories).toLocaleString("en-IN")}
                        </TableCell>
                        <TableCell className="text-sm text-right">
                          {Number(p.extendedWarranty).toLocaleString("en-IN")}
                        </TableCell>
                        <TableCell className="text-sm text-right font-semibold">
                          ₹{p.totalSales.toLocaleString("en-IN")}
                        </TableCell>
                        <TableCell className="text-sm">
                          {emp?.region ?? (
                            <span className="text-muted-foreground text-xs">
                              N/A
                            </span>
                          )}
                        </TableCell>
                      </TableRow>
                    );
                  })}
                </TableBody>
              </Table>
            </div>
          )}
        </CardContent>
      </Card>
    </div>
  );
}

// ---------------------------------------------------------------------------
// Main Uploads Page
// ---------------------------------------------------------------------------

const TABS = [
  { id: "employees", label: "Employees", icon: Users },
  { id: "parameters", label: "Parameters", icon: BarChart2 },
  { id: "attendance", label: "Attendance", icon: CalendarDays },
  { id: "swot", label: "SWOT", icon: ClipboardList },
  { id: "sales", label: "Sales", icon: TrendingUp },
  { id: "calling", label: "Calling Records", icon: Phone },
  { id: "top_performers", label: "Top Performers", icon: Trophy },
];

export default function Uploads() {
  return (
    <div className="space-y-5">
      {/* Page Header */}
      <div className="flex items-center gap-3">
        <div className="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
          <Upload size={20} className="text-primary" />
        </div>
        <div>
          <h1 className="text-xl font-bold text-foreground">Data Upload</h1>
          <p className="text-sm text-muted-foreground">
            Download templates, fill in data, and upload to populate dashboards
          </p>
        </div>
      </div>

      {/* Info Banner */}
      <div className="flex items-start gap-3 p-3.5 bg-primary/5 border border-primary/15 rounded-xl">
        <FileSpreadsheet
          size={17}
          className="text-primary mt-0.5 flex-shrink-0"
        />
        <p className="text-sm text-foreground/80">
          <span className="font-semibold text-foreground">How it works:</span>{" "}
          Click &quot;Download Template&quot; on any section, fill in your data
          following the example row, save as .xlsx or .csv, then upload and
          confirm to save to the dashboard.
        </p>
      </div>

      {/* Tabs */}
      <Tabs defaultValue="employees" className="w-full">
        <TabsList
          className="flex flex-wrap h-auto gap-1 bg-muted/50 p-1 rounded-xl mb-2"
          data-ocid="uploads.tab"
        >
          {TABS.map(({ id, label, icon: Icon }) => (
            <TabsTrigger
              key={id}
              value={id}
              className="flex items-center gap-1.5 text-xs px-3 py-2 rounded-lg data-[state=active]:bg-background data-[state=active]:shadow-sm"
              data-ocid={`uploads.${id}.tab`}
            >
              <Icon size={13} />
              {label}
            </TabsTrigger>
          ))}
        </TabsList>

        <TabsContent value="employees" className="mt-4">
          <EmployeeUploadTab />
        </TabsContent>
        <TabsContent value="parameters" className="mt-4">
          <ParametersUploadTab />
        </TabsContent>
        <TabsContent value="attendance" className="mt-4">
          <AttendanceUploadTab />
        </TabsContent>
        <TabsContent value="swot" className="mt-4">
          <SWOTUploadTab />
        </TabsContent>
        <TabsContent value="sales" className="mt-4">
          <SalesUploadTab />
        </TabsContent>
        <TabsContent value="calling" className="mt-4">
          <CallingRecordsUploadTab />
        </TabsContent>
        <TabsContent value="top_performers" className="mt-4">
          <TopPerformersTab />
        </TabsContent>
      </Tabs>
    </div>
  );
}
