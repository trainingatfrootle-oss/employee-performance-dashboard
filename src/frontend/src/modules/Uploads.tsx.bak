// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function cleanNumeric(val: unknown): string {
  return String(val ?? "")
    .replace(/₹/g, "")
    .replace(/,/g, "")
    .trim();
}

function str(val: unknown): string {
  return String(val ?? "").trim();
}

function downloadTemplate(
  filename: string,
  headers: string[],
  exampleRow: (string | number)[],
) {
  const ws = XLSX.utils.aoa_to_sheet([headers, exampleRow]);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, "Template");
  XLSX.writeFile(wb, filename);
}

async function parseWorkbook(file: File): Promise<Record<string, unknown>[]> {
  let workbook: any;
  if (file.name.endsWith(".csv")) {
    const text = await file.text();
    workbook = XLSX.read(text, { type: "string" });
  } else {
    const buffer = await file.arrayBuffer();
    workbook = XLSX.read(buffer, { type: "array" });
  }
  const sheet = workbook.Sheets[workbook.SheetNames[0]];
  return XLSX.utils.sheet_to_json(sheet, {
    defval: "",
  });
}

// ---------------------------------------------------------------------------
// Reusable Upload Section UI
// ---------------------------------------------------------------------------

interface PreviewRowBase {
  errors: string[];
}

interface UploadSectionProps<T extends PreviewRowBase> {
  tabId: string;
  title: string;
  description: string;
  icon: React.ReactNode;
  templateFilename: string;
  templateHeaders: string[];
  templateExample: (string | number)[];
  parsedRows: T[] | null;
  parseError: string | null;
  fileName: string | null;
  isPending: boolean;
  onFileSelect: (file: File) => void;
  onClear: () => void;
  onConfirm: () => void;
  tableHeaders: string[];
  renderRow: (row: T, idx: number) => React.ReactNode;
}

function UploadSection<T extends PreviewRowBase>({
  tabId,
  title,
  description,
  icon,
  templateFilename,
  templateHeaders,
  templateExample,
  parsedRows,
  parseError,
  fileName,
  isPending,
  onFileSelect,
  onClear,
  onConfirm,
  tableHeaders,
  renderRow,
}: UploadSectionProps<T>) {
  const fileInputRef = useRef<HTMLInputElement>(null);
  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];
  const invalidCount = (parsedRows?.length ?? 0) - validRows.length;

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-3">
          <div className="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center">
            {icon}
          </div>
          <div>
            <h2 className="text-base font-semibold text-foreground">{title}</h2>
            <p className="text-xs text-muted-foreground">{description}</p>
          </div>
        </div>
        <Button
          variant="outline"
          size="sm"
          onClick={() =>
            downloadTemplate(templateFilename, templateHeaders, templateExample)
          }
          data-ocid={`${tabId}.upload_button`}
        >
          <Download size={14} className="mr-1.5" />
          Download Template
        </Button>
      </div>

      <Card>
        <CardContent className="pt-5 space-y-4">
          {/* Drop Zone */}
          {!parsedRows && (
            <button
              type="button"
              className="w-full border-2 border-dashed border-border rounded-xl p-8 flex flex-col items-center gap-3 bg-muted/30 hover:bg-muted/50 transition-colors cursor-pointer"
              onClick={() => fileInputRef.current?.click()}
              data-ocid={`${tabId}.dropzone`}
            >
              <FileSpreadsheet size={36} className="text-muted-foreground" />
              <div className="text-center">
                <p className="text-sm font-medium text-foreground">
                  Click to upload .xlsx or .csv
                </p>
                <p className="text-xs text-muted-foreground mt-1">
                  Use the template above to ensure correct column names
                </p>
              </div>
              <span className="mt-1 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-border bg-background text-sm font-medium text-foreground hover:bg-muted transition-colors">
                <Upload size={13} /> Select File
              </span>
            </button>
          )}

          <input
            ref={fileInputRef}
            type="file"
            accept=".xlsx,.csv"
            onChange={(e) => {
              const file = e.target.files?.[0];
              if (file) onFileSelect(file);
              e.target.value = "";
            }}
            className="hidden"
          />

          {/* Parse Error */}
          {parseError && (
            <div
              className="flex items-start gap-2 p-3 bg-destructive/10 border border-destructive/20 rounded-lg text-sm text-destructive"
              data-ocid={`${tabId}.error_state`}
            >
              <AlertCircle size={15} className="mt-0.5 flex-shrink-0" />
              {parseError}
            </div>
          )}

          {/* Preview */}
          {parsedRows && (
            <div className="space-y-3">
              <div className="flex items-center justify-between flex-wrap gap-2">
                <div className="flex items-center gap-2 flex-wrap">
                  <span className="text-sm font-medium text-foreground">
                    Preview: {fileName}
                  </span>
                  <Badge variant="outline" className="text-xs">
                    {parsedRows.length} rows
                  </Badge>
                  <Badge
                    variant="outline"
                    className="text-xs text-green-600 border-green-300"
                  >
                    <CheckCircle2 size={11} className="mr-1" />
                    {validRows.length} valid
                  </Badge>
                  {invalidCount > 0 && (
                    <Badge
                      variant="outline"
                      className="text-xs text-destructive border-destructive/30"
                    >
                      <AlertCircle size={11} className="mr-1" />
                      {invalidCount} invalid
                    </Badge>
                  )}
                </div>
                <div className="flex gap-2">
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={onClear}
                    data-ocid={`${tabId}.cancel_button`}
                  >
                    <X size={13} className="mr-1" /> Clear
                  </Button>
                  <Button
                    size="sm"
                    onClick={onConfirm}
                    disabled={validRows.length === 0 || isPending}
                    data-ocid={`${tabId}.submit_button`}
                  >
                    {isPending ? (
                      <Loader2 size={13} className="mr-1 animate-spin" />
                    ) : (
                      <CheckCircle2 size={13} className="mr-1" />
                    )}
                    {isPending ? "Saving..." : "Confirm & Save"}
                  </Button>
                </div>
              </div>

              <ScrollArea className="h-72 rounded-lg border border-border">
                <Table>
                  <TableHeader>
                    <TableRow className="bg-muted/50">
                      {tableHeaders.map((h) => (
                        <TableHead
                          key={h}
                          className="text-xs whitespace-nowrap"
                        >
                          {h}
                        </TableHead>
                      ))}
                      <TableHead className="text-xs">Status</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {
                      // biome-ignore lint/suspicious/noArrayIndexKey: no stable id
                      parsedRows.map((row, idx) => (
                        <TableRow
                          // biome-ignore lint/suspicious/noArrayIndexKey: parsed rows have no stable id
                          key={`row-${idx}`}
                          data-ocid={`${tabId}.item.${idx + 1}`}
                          className={row.errors.length > 0 ? "bg-red-50" : ""}
                        >
                          {renderRow(row, idx)}
                          <TableCell className="text-xs">
                            {row.errors.length > 0 ? (
                              <span className="text-destructive flex items-start gap-1">
                                <AlertCircle
                                  size={11}
                                  className="mt-0.5 flex-shrink-0"
                                />
                                {row.errors.join("; ")}
                              </span>
                            ) : (
                              <span className="text-green-600 flex items-center gap-1">
                                <CheckCircle2 size={11} /> Valid
                              </span>
                            )}
                          </TableCell>
                        </TableRow>
                      ))
                    }
                  </TableBody>
                </Table>
              </ScrollArea>
            </div>
          )}

          {/* Empty state */}
          {!parsedRows && !parseError && (
            <div
              className="flex flex-col items-center justify-center py-6 text-center text-muted-foreground gap-2"
              data-ocid={`${tabId}.empty_state`}
            >
              <FileSpreadsheet size={28} className="opacity-30" />
              <p className="text-xs">No file uploaded yet.</p>
            </div>
          )}
        </CardContent>
      </Card>
    </div>
  );
}

// ---------------------------------------------------------------------------
// Tab: Employee Upload
// ---------------------------------------------------------------------------

interface EmployeeRow extends PreviewRowBase {
  fiplCode: string;
  name: string;
  role: string;
  department: string;
  fseCategory: string;
  status: string;
  joinDate: string;
  avatarUrl: string;
  region: string;
  familyDetails: string;
  pastExperience: string;
}

const EMPLOYEE_HEADERS = [
  "FIPL Code",
  "Name",
  "Role",
  "Department",
  "FSE Category",
  "Status",
  "Joining Date (DD-MM-YYYY)",
  "Avatar URL",
  "Region",
  "Family Details",
  "Past Experience",
];

function parseEmployeeRows(rawRows: Record<string, unknown>[]): EmployeeRow[] {
  return rawRows
    .filter((r) => EMPLOYEE_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const fiplCode = str(r["FIPL Code"]);
      const name = str(r.Name);
      const status = str(r.Status);

      if (!fiplCode) errors.push("FIPL Code is required");
      if (!name) errors.push("Name is required");
      const statusNorm = status.toLowerCase();
      if (status && statusNorm !== "active" && statusNorm !== "on hold") {
        errors.push('Status must be "Active" or "On Hold"');
      }

      return {
        fiplCode,
        name,
        role: str(r.Role),
        department: str(r.Department),
        fseCategory: str(r["FSE Category"]),
        status,
        joinDate: str(r["Joining Date (DD-MM-YYYY)"]),
        avatarUrl: str(r["Avatar URL"]),
        region: str(r.Region),
        familyDetails: str(r["Family Details"]),
        pastExperience: str(r["Past Experience"]),
        errors,
      };
    });
}

function EmployeeUploadTab() {
  const { actor } = useActor();
  const queryClient = useQueryClient();
  const [parsedRows, setParsedRows] = useState<EmployeeRow[] | null>(null);
  const [parseError, setParseError] = useState<string | null>(null);
  const [fileName, setFileName] = useState<string | null>(null);

  const mutation = useMutation({
    mutationFn: async (records: Employee[]) => {
      if (!actor) throw new Error("Not connected");
      return actor.batchEmployeeUpload(records);
    },
    onSuccess: (result) => {
      toast.success(
        `${Number(result.successCount)} rows uploaded, ${Number(result.failCount)} failed`,
      );
      queryClient.invalidateQueries({ queryKey: ["employees"] });
      setParsedRows(null);
      setFileName(null);
    },
    onError: (err) => toast.error(`Upload failed: ${String(err)}`),
  });

  const handleFileSelect = async (file: File) => {
    setParseError(null);
    setParsedRows(null);
    setFileName(file.name);
    try {
      const rawRows = await parseWorkbook(file);
      if (rawRows.length === 0) {
        setParseError("File is empty.");
        return;
      }
      const missing = EMPLOYEE_HEADERS.filter((h) => !(h in rawRows[0]));
      if (missing.length > 0) {
        setParseError(`Missing columns: ${missing.join(", ")}`);
        return;
      }
      setParsedRows(parseEmployeeRows(rawRows));
    } catch (e) {
      setParseError(`Failed to parse: ${String(e)}`);
    }
  };

  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];

  const handleConfirm = () => {
    const records: Employee[] = validRows.map((r) => ({
      fiplCode: r.fiplCode,
      name: r.name,
      role: r.role,
      department: r.department,
      fseCategory: r.fseCategory,
      status:
        r.status.toLowerCase() === "active"
          ? Variant_active_onHold.active
          : Variant_active_onHold.onHold,
      joinDate: r.joinDate,
      avatarUrl: r.avatarUrl,
      region: r.region,
      familyDetails: r.familyDetails,
      pastExperience: r.pastExperience,
    }));
    mutation.mutate(records);
  };

  return (
    <UploadSection<EmployeeRow>
      tabId="employee_upload"
      title="Employee Upload"
      description="Upload employee master data. FIPL Code is the unique identifier."
      icon={<Users size={17} className="text-primary" />}
      templateFilename="employee_template.xlsx"
      templateHeaders={EMPLOYEE_HEADERS}
      templateExample={[
        "FIPL001",
        "Rahul Sharma",
        "Field Sales Executive",
        "Sales",
        "A",
        "Active",
        "01-01-2023",
        "",
        "North",
        "Married, 2 children",
        "5 years in FMCG",
      ]}
      parsedRows={parsedRows}
      parseError={parseError}
      fileName={fileName}
      isPending={mutation.isPending}
      onFileSelect={handleFileSelect}
      onClear={() => {
        setParsedRows(null);
        setFileName(null);
        setParseError(null);
      }}
      onConfirm={handleConfirm}
      tableHeaders={[
        "FIPL Code",
        "Name",
        "Role",
        "Department",
        "FSE Category",
        "Status",
        "Join Date",
        "Region",
      ]}
      renderRow={(row) => (
        <>
          <TableCell className="font-mono text-xs">
            {row.fiplCode || "—"}
          </TableCell>
          <TableCell className="text-sm">{row.name || "—"}</TableCell>
          <TableCell className="text-xs">{row.role || "—"}</TableCell>
          <TableCell className="text-xs">{row.department || "—"}</TableCell>
          <TableCell className="text-xs">{row.fseCategory || "—"}</TableCell>
          <TableCell className="text-xs">
            <Badge
              variant="outline"
              className={`text-xs ${
                row.status.toLowerCase() === "active"
                  ? "text-green-600 border-green-300"
                  : row.status.toLowerCase() === "on hold"
                    ? "text-amber-600 border-amber-300"
                    : "text-destructive border-destructive/30"
              }`}
            >
              {row.status || "—"}
            </Badge>
          </TableCell>
          <TableCell className="text-xs">{row.joinDate || "—"}</TableCell>
          <TableCell className="text-xs">{row.region || "—"}</TableCell>
        </>
      )}
    />
  );
}

// ---------------------------------------------------------------------------
// Tab: Parameters Upload
// ---------------------------------------------------------------------------

interface ParametersRow extends PreviewRowBase {
  fiplCode: string;
  name: string;
  salesInfluenceIndex: number;
  reviewCount: number;
  operationalDiscipline: number;
  productKnowledgeScore: number;
  softSkillsScore: number;
  demoVisits: number;
  complaintVisits: number;
  videoCallDemos: number;
}

const PARAMETERS_HEADERS = [
  "FIPL Code",
  "Name",
  "Sales Influence Index",
  "Review Count",
  "Operational Discipline",
  "Product Knowledge Score",
  "Soft Skills Score",
  "Total Demo Visits",
  "Total Complaint Visits",
  "Total Video Call Demos",
];

function parseParametersRows(
  rawRows: Record<string, unknown>[],
  employeeSet: Set<string>,
): ParametersRow[] {
  return rawRows
    .filter((r) => PARAMETERS_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const fiplCode = str(r["FIPL Code"]);

      if (!fiplCode) errors.push("FIPL Code is required");
      else if (!employeeSet.has(fiplCode.toUpperCase()))
        errors.push("Invalid FIPL Code");

      const parseNum = (key: string, label: string): number => {
        const raw = cleanNumeric(r[key]);
        const n = Number(raw);
        if (raw === "" || Number.isNaN(n) || n < 0) {
          errors.push(`Invalid number (${label})`);
          return 0;
        }
        return n;
      };

      return {
        fiplCode,
        name: str(r.Name),
        salesInfluenceIndex: parseNum(
          "Sales Influence Index",
          "Sales Influence Index",
        ),
        reviewCount: parseNum("Review Count", "Review Count"),
        operationalDiscipline: parseNum(
          "Operational Discipline",
          "Operational Discipline",
        ),
        productKnowledgeScore: parseNum(
          "Product Knowledge Score",
          "Product Knowledge Score",
        ),
        softSkillsScore: parseNum("Soft Skills Score", "Soft Skills Score"),
        demoVisits: parseNum("Total Demo Visits", "Demo Visits"),
        complaintVisits: parseNum("Total Complaint Visits", "Complaint Visits"),
        videoCallDemos: parseNum("Total Video Call Demos", "Video Call Demos"),
        errors,
      };
    });
}

function ParametersUploadTab() {
  const { actor, isFetching } = useActor();
  const queryClient = useQueryClient();
  const [parsedRows, setParsedRows] = useState<ParametersRow[] | null>(null);
  const [parseError, setParseError] = useState<string | null>(null);
  const [fileName, setFileName] = useState<string | null>(null);

  const { data: employees = [] } = useQuery({
    queryKey: ["employees"],
    queryFn: async () => (actor ? actor.getAllEmployees() : []),
    enabled: !!actor && !isFetching,
  });
  const employeeSet = new Set(
    employees.map((e) => e.fiplCode.trim().toUpperCase()),
  );

  const mutation = useMutation({
    mutationFn: async (records: Performance[]) => {
      if (!actor) throw new Error("Not connected");
      return actor.batchParametersUpload(records);
    },
    onSuccess: (result) => {
      toast.success(
        `${Number(result.successCount)} rows uploaded, ${Number(result.failCount)} failed`,
      );
      queryClient.invalidateQueries({ queryKey: ["performances"] });
      setParsedRows(null);
      setFileName(null);
    },
    onError: (err) => toast.error(`Upload failed: ${String(err)}`),
  });

  const handleFileSelect = async (file: File) => {
    setParseError(null);
    setParsedRows(null);
    setFileName(file.name);
    try {
      const rawRows = await parseWorkbook(file);
      if (rawRows.length === 0) {
        setParseError("File is empty.");
        return;
      }
      const missing = PARAMETERS_HEADERS.filter((h) => !(h in rawRows[0]));
      if (missing.length > 0) {
        setParseError(`Missing columns: ${missing.join(", ")}`);
        return;
      }
      setParsedRows(parseParametersRows(rawRows, employeeSet));
    } catch (e) {
      setParseError(`Failed to parse: ${String(e)}`);
    }
  };

  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];

  const handleConfirm = () => {
    const records: Performance[] = validRows.map((r) => ({
      fiplCode: r.fiplCode,
      salesInfluenceIndex: r.salesInfluenceIndex,
      reviewCount: BigInt(Math.round(r.reviewCount)),
      operationalDiscipline: r.operationalDiscipline,
      productKnowledgeScore: r.productKnowledgeScore,
      softSkillsScore: r.softSkillsScore,
      demoVisits: BigInt(Math.round(r.demoVisits)),
      complaintVisits: BigInt(Math.round(r.complaintVisits)),
      videoCallDemos: BigInt(Math.round(r.videoCallDemos)),
    }));
    mutation.mutate(records);
  };

  return (
    <UploadSection<ParametersRow>
      tabId="parameters_upload"
      title="Parameters Upload (FSE Performance)"
      description="Upload FSE performance metrics. All numeric fields must be valid non-negative numbers."
      icon={<BarChart2 size={17} className="text-primary" />}
      templateFilename="parameters_template.xlsx"
      templateHeaders={PARAMETERS_HEADERS}
      templateExample={[
        "FIPL001",
        "Rahul Sharma",
        85,
        12,
        90,
        88,
        76,
        24,
        5,
        10,
      ]}
      parsedRows={parsedRows}
      parseError={parseError}
      fileName={fileName}
      isPending={mutation.isPending}
      onFileSelect={handleFileSelect}
      onClear={() => {
        setParsedRows(null);
        setFileName(null);
        setParseError(null);
      }}
      onConfirm={handleConfirm}
      tableHeaders={[
        "FIPL Code",
        "Name",
        "SII",
        "Reviews",
        "Op. Discipline",
        "Product Score",
        "Soft Skills",
        "Demo",
        "Complaint",
        "Video",
      ]}
      renderRow={(row) => (
        <>
          <TableCell className="font-mono text-xs">
            {row.fiplCode || "—"}
          </TableCell>
          <TableCell className="text-sm">{row.name || "—"}</TableCell>
          <TableCell className="text-xs text-right">
            {row.salesInfluenceIndex}
          </TableCell>
          <TableCell className="text-xs text-right">
            {row.reviewCount}
          </TableCell>
          <TableCell className="text-xs text-right">
            {row.operationalDiscipline}
          </TableCell>
          <TableCell className="text-xs text-right">
            {row.productKnowledgeScore}
          </TableCell>
          <TableCell className="text-xs text-right">
            {row.softSkillsScore}
          </TableCell>
          <TableCell className="text-xs text-right">{row.demoVisits}</TableCell>
          <TableCell className="text-xs text-right">
            {row.complaintVisits}
          </TableCell>
          <TableCell className="text-xs text-right">
            {row.videoCallDemos}
          </TableCell>
        </>
      )}
    />
  );
}

// ---------------------------------------------------------------------------
// Tab: Attendance Upload
// ---------------------------------------------------------------------------

const ATTENDANCE_LAB_TYPES = [
  "Attendance Lapses",
  "EOD Picture Lapses",
  "Days Brief Lapses",
];

interface AttendanceRow extends PreviewRowBase {
  fiplCode: string;
  fseName: string;
  labType: string;
  daysOff: number;
  reason: string;
  date: string;
}

const ATTENDANCE_HEADERS = [
  "FIPL Code",
  "FSE Name",
  "Type of Lapses",
  "Days Taken Off",
  "Reason for Day Off",
  "Date (DD-MM-YYYY)",
];

function parseAttendanceRows(
  rawRows: Record<string, unknown>[],
  employeeSet: Set<string>,
): AttendanceRow[] {
  return rawRows
    .filter((r) => ATTENDANCE_HEADERS.some((h) => str(r[h]) !== ""))
    .map((r) => {
      const errors: string[] = [];
      const fiplCode = str(r["FIPL Code"]);
      const labType = str(r["Type of Lapses"]);
      const daysRaw = cleanNumeric(r["Days Taken Off"]);
      const days = Number(daysRaw);

      if (!fiplCode) errors.push("FIPL Code is required");
      else if (!employeeSet.has(fiplCode.toUpperCase()))
        errors.push("Invalid FIPL Code");

      if (!ATTENDANCE_LAB_TYPES.includes(labType)) {
        errors.push(`Type must be one of: ${ATTENDANCE_LAB_TYPES.join(", ")}`);
      }
      if (daysRaw === "" || Number.isNaN(days) || days < 0) {
        errors.push("Days Taken Off must be >= 0");
      }

      return {
        fiplCode,
        fseName: str(r["FSE Name"]),
        labType,
        daysOff: Number.isNaN(days) ? 0 : days,
        reason: str(r["Reason for Day Off"]),
