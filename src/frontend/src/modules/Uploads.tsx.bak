      if (rawRows.length === 0) {
        setParseError("File is empty.");
        return;
      }
      const missing = CALLING_HEADERS.filter((h) => !(h in rawRows[0]));
      if (missing.length > 0) {
        setParseError(`Missing columns: ${missing.join(", ")}`);
        return;
      }
      setParsedRows(parseCallingRows(rawRows, employeeSet));
    } catch (e) {
      setParseError(`Failed to parse: ${String(e)}`);
    }
  };

  const validRows = parsedRows?.filter((r) => r.errors.length === 0) ?? [];

  const handleConfirm = () => {
    const records: FeedbackEntry[] = validRows.map((r) => ({
      entryId: 0n,
      fiplCode: r.fiplCode,
