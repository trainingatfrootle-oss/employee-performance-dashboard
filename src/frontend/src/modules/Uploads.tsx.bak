    }));
    mutation.mutate(records);
  };

  return (
    <UploadSection<SWOTRow>
      tabId="swot_upload"
      title="SWOT Upload"
      description="Upload SWOT analysis data. Use semicolons to separate multiple values (e.g. Leadership; Communication)."
